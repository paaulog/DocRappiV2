    "endpoint-authorize-payment": {
      "id": "endpoint-authorize-payment",
      "title": "Endpoint: autorizar pago",
      "method": "POST",
      "endpoint": "/payless/v1/payments/authorize",
      "sections": [
        { "type": "text", "title": "Explicación de negocio", "content": "Autoriza la transacción para continuar el flujo." },
        { "type": "kv", "title": "Posición del flujo", "items": [ { "label": "Fase", "value": "Payment Flow" } ] },
        { "type": "callout", "variant": "warning", "title": "Precondiciones", "content": "Token válido y transaction_id idempotente." },
        { "type": "code", "title": "Request example", "lang": "json", "code": "{\n  \"transaction_id\": \"txn_100200\",\n  \"amount\": 12590,\n  \"currency\": \"BRL\"\n}" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{ \"status\": \"AUTHORIZED\" }" },
        { "type": "errors", "title": "Errores", "rows": [ { "code": 400, "status": "Bad Request", "description": "Payload inválido." } ] },
        { "type": "code", "title": "Snippet", "lang": "bash", "code": "curl -X POST https://api.example.com/payless/v1/payments/authorize" }
      ]
    },
    "endpoint-validate-payment": {
      "id": "endpoint-validate-payment",
      "title": "Endpoint: validar pago",
      "method": "POST",
      "endpoint": "/payless/v1/payments/validate",
      "sections": [
        { "type": "text", "title": "Explicación de negocio", "content": "Reduce errores validando antes de autorizar." },
        { "type": "kv", "title": "Posición del flujo", "items": [ { "label": "Fase", "value": "Authentication & Validation" } ] },
        { "type": "callout", "variant": "warning", "title": "Precondiciones", "content": "Token y campos requeridos." },
        { "type": "code", "title": "Request example", "lang": "json", "code": "{ \"transaction_id\": \"txn_100200\" }" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{ \"valid\": true }" },
        { "type": "errors", "title": "Errores", "rows": [ { "code": 409, "status": "Conflict", "description": "Duplicado." } ] },
        { "type": "code", "title": "Snippet", "lang": "javascript", "code": "await fetch('/payless/v1/payments/validate', { method: 'POST' })" }
      ]
    },
    "endpoint-cancel-transaction": {
      "id": "endpoint-cancel-transaction",
      "title": "Endpoint: cancelar transacción",
      "method": "POST",
      "endpoint": "/payless/v1/transactions/{id}/cancel",
      "sections": [
        { "type": "text", "title": "Explicación de negocio", "content": "Revierte transacciones elegibles." },
        { "type": "kv", "title": "Posición del flujo", "items": [ { "label": "Fase", "value": "Transaction Management" } ] },
        { "type": "callout", "variant": "warning", "title": "Precondiciones", "content": "Estado válido para cancelación." },
        { "type": "code", "title": "Request example", "lang": "json", "code": "{ \"reason\": \"ORDER_ABORTED\" }" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{ \"status\": \"CANCELED\" }" },
        { "type": "errors", "title": "Errores", "rows": [ { "code": 422, "status": "Unprocessable Entity", "description": "Estado inválido." } ] },
        { "type": "code", "title": "Snippet", "lang": "python", "code": "requests.post(url, json={\"reason\":\"ORDER_ABORTED\"})" }
      ]
    },
    "endpoint-refund-transaction": {
      "id": "endpoint-refund-transaction",
      "title": "Endpoint: refund",
      "method": "POST",
      "endpoint": "/payless/v1/transactions/{id}/refund",
      "sections": [
        { "type": "text", "title": "Explicación de negocio", "content": "Aplica estorno de transacción liquidada." },
        { "type": "kv", "title": "Posición del flujo", "items": [ { "label": "Fase", "value": "Transaction Management" } ] },
        { "type": "callout", "variant": "warning", "title": "Precondiciones", "content": "Monto y razón válidos." },
        { "type": "code", "title": "Request example", "lang": "json", "code": "{ \"amount\": 5000 }" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{ \"refund_status\": \"PROCESSING\" }" },
        { "type": "errors", "title": "Errores", "rows": [ { "code": 409, "status": "Conflict", "description": "Refund duplicado." } ] },
        { "type": "code", "title": "Snippet", "lang": "bash", "code": "curl -X POST https://api.example.com/payless/v1/transactions/{id}/refund" }
      ]
    },
    "endpoint-heartbeat": {
      "id": "endpoint-heartbeat",
      "title": "Endpoint: heartbeat",
      "method": "GET",
      "endpoint": "/payless/v1/heartbeat",
      "sections": [
        { "type": "text", "title": "Explicación de negocio", "content": "Verifica disponibilidad del servicio." },
        { "type": "kv", "title": "Posición del flujo", "items": [ { "label": "Fase", "value": "System Monitoring & Health" } ] },
        { "type": "callout", "variant": "info", "title": "Precondiciones", "content": "Ejecutar chequeos periódicos con alertas." },
        { "type": "code", "title": "Request example", "lang": "http", "code": "GET /payless/v1/heartbeat HTTP/1.1" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{ \"status\": \"UP\" }" },
        { "type": "errors", "title": "Errores", "rows": [ { "code": 503, "status": "Service Unavailable", "description": "Dependencia caída." } ] },
        { "type": "code", "title": "Snippet", "lang": "bash", "code": "curl -fsS https://api.example.com/payless/v1/heartbeat" }
      ]
    }
