    "endpoint-authorize-payment": {
      "id": "endpoint-authorize-payment",
      "title": "Endpoint: authorize payment",
      "method": "POST",
      "endpoint": "/payless/v1/payments/authorize",
      "description": "Authorize a payment transaction after validation.",
      "sections": [
        { "type": "text", "title": "Business explanation", "content": "Authorizes charge continuation in checkout flow." },
        {
          "type": "kv",
          "title": "Flow positioning",
          "items": [
            { "label": "Phase", "value": "Payment Flow" },
            { "label": "Depends on", "value": "Authentication & Validation" }
          ]
        },
        {
          "type": "params",
          "title": "Preconditions",
          "rows": [
            { "name": "access_token", "type": "string", "required": true, "description": "Valid authentication token." },
            { "name": "transaction_id", "type": "string", "required": true, "description": "Idempotent transaction key." }
          ]
        },
        { "type": "code", "title": "Request example", "lang": "json", "code": "{\n  \"transaction_id\": \"txn_100200\",\n  \"amount\": 12590,\n  \"currency\": \"BRL\",\n  \"payment_method\": \"CARD\"\n}" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{\n  \"status\": \"AUTHORIZED\",\n  \"auth_code\": \"A12345\",\n  \"transaction_id\": \"txn_100200\"\n}" },
        {
          "type": "errors",
          "title": "Possible errors",
          "rows": [
            { "code": 400, "status": "Bad Request", "description": "Invalid payload." },
            { "code": 401, "status": "Unauthorized", "description": "Invalid/expired token." },
            { "code": 422, "status": "Unprocessable Entity", "description": "Transaction not eligible for authorization." }
          ]
        },
        { "type": "code", "title": "Technology snippet (cURL)", "lang": "bash", "code": "curl -X POST https://api.example.com/payless/v1/payments/authorize \\\n  -H \"Authorization: Bearer {access_token}\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"transaction_id\":\"txn_100200\",\"amount\":12590,\"currency\":\"BRL\",\"payment_method\":\"CARD\"}'" }
      ]
    },
    "endpoint-validate-payment": {
      "id": "endpoint-validate-payment",
      "title": "Endpoint: validate payment",
      "method": "POST",
      "endpoint": "/payless/v1/payments/validate",
      "description": "Validate payment payload and eligibility before authorization.",
      "sections": [
        { "type": "text", "title": "Business explanation", "content": "Validates early to reduce late-stage payment failures." },
        {
          "type": "kv",
          "title": "Flow positioning",
          "items": [
            { "label": "Phase", "value": "Authentication & Validation" },
            { "label": "Next", "value": "Payment Flow" }
          ]
        },
        { "type": "callout", "variant": "warning", "title": "Preconditions", "content": "Valid token and normalized required fields are mandatory." },
        { "type": "code", "title": "Request example", "lang": "json", "code": "{\n  \"transaction_id\": \"txn_100200\",\n  \"amount\": 12590,\n  \"currency\": \"BRL\",\n  \"payment_method\": \"CARD\"\n}" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{\n  \"valid\": true,\n  \"reasons\": []\n}" },
        {
          "type": "errors",
          "title": "Possible errors",
          "rows": [
            { "code": 400, "status": "Bad Request", "description": "Missing required fields." },
            { "code": 409, "status": "Conflict", "description": "Duplicate transaction reference." }
          ]
        },
        { "type": "code", "title": "Technology snippet (Node.js)", "lang": "javascript", "code": "await fetch('/payless/v1/payments/validate', {\n  method: 'POST',\n  headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },\n  body: JSON.stringify(payload)\n});" }
      ]
    },
    "endpoint-cancel-transaction": {
      "id": "endpoint-cancel-transaction",
      "title": "Endpoint: cancel transaction",
      "method": "POST",
      "endpoint": "/payless/v1/transactions/{id}/cancel",
      "description": "Cancel eligible transactions.",
      "sections": [
        { "type": "text", "title": "Business explanation", "content": "Used to revert authorized transactions before settlement." },
        {
          "type": "kv",
          "title": "Flow positioning",
          "items": [
            { "label": "Phase", "value": "Transaction Management" },
            { "label": "Dependency", "value": "Authorized transaction state" }
          ]
        },
        {
          "type": "params",
          "title": "Preconditions",
          "rows": [
            { "name": "transaction_status", "type": "string", "required": true, "description": "State must allow cancellation." }
          ]
        },
        { "type": "code", "title": "Request example", "lang": "json", "code": "{\n  \"reason\": \"ORDER_ABORTED\"\n}" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{\n  \"status\": \"CANCELED\",\n  \"transaction_id\": \"txn_100200\"\n}" },
        {
          "type": "errors",
          "title": "Possible errors",
          "rows": [
            { "code": 404, "status": "Not Found", "description": "Transaction not found." },
            { "code": 422, "status": "Unprocessable Entity", "description": "Invalid state for cancellation." }
          ]
        },
        { "type": "code", "title": "Technology snippet (Python)", "lang": "python", "code": "requests.post(url, headers=headers, json={\"reason\": \"ORDER_ABORTED\"})" }
      ]
    },
    "endpoint-refund-transaction": {
      "id": "endpoint-refund-transaction",
      "title": "Endpoint: refund transaction",
      "method": "POST",
      "endpoint": "/payless/v1/transactions/{id}/refund",
      "description": "Request refund for settled transactions.",
      "sections": [
        { "type": "text", "title": "Business explanation", "content": "Used for partial or full reversals after capture/settlement." },
        {
          "type": "kv",
          "title": "Flow positioning",
          "items": [
            { "label": "Phase", "value": "Transaction Management" },
            { "label": "Dependency", "value": "Captured/settled transaction" }
          ]
        },
        { "type": "callout", "variant": "warning", "title": "Preconditions", "content": "Provide a valid refund amount and auditable reason." },
        { "type": "code", "title": "Request example", "lang": "json", "code": "{\n  \"amount\": 5000,\n  \"reason\": \"CUSTOMER_REQUEST\"\n}" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{\n  \"refund_status\": \"PROCESSING\",\n  \"refund_id\": \"rf_9988\"\n}" },
        {
          "type": "errors",
          "title": "Possible errors",
          "rows": [
            { "code": 400, "status": "Bad Request", "description": "Invalid refund amount." },
            { "code": 409, "status": "Conflict", "description": "Duplicate refund request." }
          ]
        },
        { "type": "code", "title": "Technology snippet (cURL)", "lang": "bash", "code": "curl -X POST https://api.example.com/payless/v1/transactions/txn_100200/refund \\\n  -H \"Authorization: Bearer {access_token}\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"amount\":5000,\"reason\":\"CUSTOMER_REQUEST\"}'" }
      ]
    },
    "endpoint-heartbeat": {
      "id": "endpoint-heartbeat",
      "title": "Endpoint: heartbeat",
      "method": "GET",
      "endpoint": "/payless/v1/heartbeat",
      "description": "Check service availability and dependency status.",
      "sections": [
        { "type": "text", "title": "Business explanation", "content": "Used by monitoring stacks to ensure the payment service is healthy." },
        {
          "type": "kv",
          "title": "Flow positioning",
          "items": [
            { "label": "Phase", "value": "System Monitoring & Health" },
            { "label": "Usage", "value": "Periodic uptime checks" }
          ]
        },
        { "type": "callout", "variant": "info", "title": "Preconditions", "content": "Schedule checks and alert on consecutive failures." },
        { "type": "code", "title": "Request example", "lang": "http", "code": "GET /payless/v1/heartbeat HTTP/1.1\nHost: api.example.com\nAuthorization: Bearer {access_token}" },
        { "type": "code", "title": "Response example", "lang": "json", "code": "{\n  \"status\": \"UP\",\n  \"timestamp\": \"2026-03-23T12:00:00Z\",\n  \"dependencies\": { \"db\": \"UP\", \"queue\": \"UP\" }\n}" },
        {
          "type": "errors",
          "title": "Possible errors",
          "rows": [
            { "code": 503, "status": "Service Unavailable", "description": "One or more dependencies unavailable." }
          ]
        },
        { "type": "code", "title": "Technology snippet (bash)", "lang": "bash", "code": "curl -fsS https://api.example.com/payless/v1/heartbeat || echo \"ALERT: service unavailable\"" }
      ]
    }
  }
}
        }
      ]
    }
  }
